<?xml version='1.0' encoding='utf-8'?>
<widget id="com.example.discountcard" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Discount Cards</name>
    <description>
        A mobile app for storing and managing discount cards with QR codes
    </description>
    <author email="developer@example.com" href="https://example.com">
        Discount Card App Team
    </author>
    
    <content src="index.html" />
    
    <!-- Network Access -->
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    
    <!-- Platform-specific settings -->
    <platform name="android">
        <allow-intent href="market:*" />
        
        <!-- App permissions -->
        <uses-permission android:name="android.permission.CAMERA" />
        <uses-permission android:name="android.permission.FLASHLIGHT" />
        <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
        <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
        
        <!-- Camera features -->
        <uses-feature android:name="android.hardware.camera" android:required="false" />
        <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
        <uses-feature android:name="android.hardware.camera.flash" android:required="false" />
        
        <!-- App icon and splash screen -->
        <icon density="ldpi" src="www/img/icon-ldpi.png" />
        <icon density="mdpi" src="www/img/icon-mdpi.png" />
        <icon density="hdpi" src="www/img/icon-hdpi.png" />
        <icon density="xhdpi" src="www/img/icon-xhdpi.png" />
        <icon density="xxhdpi" src="www/img/icon-xxhdpi.png" />
        <icon density="xxxhdpi" src="www/img/icon-xxxhdpi.png" />
        
        <!-- Android specific preferences -->
        <preference name="android-minSdkVersion" value="22" />
        <preference name="android-targetSdkVersion" value="34" />
        <preference name="StatusBarOverlaysWebView" value="false" />
        <preference name="StatusBarBackgroundColor" value="#007bff" />
        <preference name="StatusBarStyle" value="lightcontent" />
    </platform>
    
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        
        <!-- iOS permissions -->
        <config-file target="*-Info.plist" parent="NSCameraUsageDescription">
            <string>This app needs access to camera to scan QR codes on discount cards</string>
        </config-file>
        <config-file target="*-Info.plist" parent="NSPhotoLibraryUsageDescription">
            <string>This app needs access to photo library to save QR code images</string>
        </config-file>
        
        <!-- App icons -->
        <icon height="57" src="www/img/icon-57.png" width="57" />
        <icon height="114" src="www/img/icon-57@2x.png" width="114" />
        <icon height="72" src="www/img/icon-72.png" width="72" />
        <icon height="144" src="www/img/icon-72@2x.png" width="144" />
        <icon height="60" src="www/img/icon-60.png" width="60" />
        <icon height="120" src="www/img/icon-60@2x.png" width="120" />
        <icon height="180" src="www/img/icon-60@3x.png" width="180" />
        <icon height="76" src="www/img/icon-76.png" width="76" />
        <icon height="152" src="www/img/icon-76@2x.png" width="152" />
        <icon height="40" src="www/img/icon-40.png" width="40" />
        <icon height="80" src="www/img/icon-40@2x.png" width="80" />
        <icon height="120" src="www/img/icon-40@3x.png" width="120" />
        <icon height="29" src="www/img/icon-small.png" width="29" />
        <icon height="58" src="www/img/icon-small@2x.png" width="58" />
        <icon height="87" src="www/img/icon-small@3x.png" width="87" />
        <icon height="167" src="www/img/icon-83.5@2x.png" width="167" />
        <icon height="1024" src="www/img/icon-1024.png" width="1024" />
    </platform>
    
    <!-- Global preferences -->
    <preference name="DisallowOverscroll" value="true" />
    <preference name="android-minSdkVersion" value="22" />
    <preference name="BackupWebStorage" value="local" />
    <preference name="SplashScreenDelay" value="2000" />
    <preference name="FadeSplashScreenDuration" value="500" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    <preference name="Orientation" value="portrait" />
    
    <!-- Content Security Policy -->
    <preference name="ContentSecurityPolicy" value="default-src 'self' data: gap: https://ssl.gstatic.com 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; img-src 'self' data: content: https:; media-src 'self' https:; font-src 'self' data: https://cdn.jsdelivr.net;" />
    
    <!-- File storage preferences -->
    <preference name="AndroidPersistentFileLocation" value="Internal" />
    <preference name="iosPersistentFileLocation" value="Library" />
</widget>
